{
  "name": "mall-superapp",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "release:notes": "changeset version || true",
    "build:mobile:node20:docker": "docker run --rm -v $PWD:/workspace -w /workspace node:20-bullseye bash -lc 'corepack enable && pnpm i --frozen-lockfile && pnpm --filter @mall/mobile build'"
  },
  "volta": {
    "node": "20.19.0",
    "pnpm": "10.7.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6"
  }
}
